# AutoRadar — єдиний env-файл для всіх сервісів
# cp .env.example .env

# ── Backend ──────────────────────────────────────────────────────────────────
# SQLite у папці database/
DATABASE_URL=sqlite+aiosqlite:///database/autoradar.db
# KV store (SQLite у database/kv.db)
REDIS_URL=sqlite://database/kv.db
SECRET_KEY=change-me-in-production

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=AutoRadar <info@13vplus.com>
FRONTEND_URL=http://localhost:3000

# OAuth (redirect URI додайте в Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# External APIs
AUTO_RIA_API_KEY=
OLX_CLIENT_ID=
OLX_CLIENT_SECRET=

# Admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Internal API (bot → backend, має збігатися в обох сервісах)
INTERNAL_API_SECRET=change-me-internal

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# @username бота (без @) — використовується backend, bot і frontend
TELEGRAM_BOT_USERNAME=
# Необов'язково: повне посилання t.me/... (якщо порожньо — збирається з username)
TELEGRAM_BOT_URL=
# Публічний URL API (frontend, bot локально; у Docker bot отримує внутрішній URL з compose)
BACKEND_URL=http://localhost:8000/api/v1

# ── Docker (production) ──────────────────────────────────────────────────────
# FRONTEND_URL=https://your-domain.com
# BACKEND_URL=https://your-domain.com/api/v1
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/v1/auth/google/callback
# FRONTEND_PORT=3000
# BACKEND_PORT=8000
# Детальні інструкції: DOCKER.md
